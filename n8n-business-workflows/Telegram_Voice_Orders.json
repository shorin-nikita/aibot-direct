{
  "name": "📱 Голосовые заказы через Telegram",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message"
        ]
      },
      "id": "telegram-trigger",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1,
      "position": [260, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{$json.message.voice}}",
              "rightValue": "",
              "operator": {
                "type": "object",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-voice-message",
      "name": "Проверка голосового сообщения",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "url": "https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/getFile",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "file_id",
              "value": "={{$json.message.voice.file_id}}"
            }
          ]
        }
      },
      "id": "get-voice-file",
      "name": "Получить голосовой файл",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [700, 300]
    },
    {
      "parameters": {
        "url": "https://api.telegram.org/file/bot{{$env.TELEGRAM_BOT_TOKEN}}/{{$json.result.file_path}}",
        "responseFormat": "file"
      },
      "id": "download-voice",
      "name": "Скачать голос",
      "type": "n8n-nodes-base.httpRequest", 
      "typeVersion": 4.1,
      "position": [920, 300]
    },
    {
      "parameters": {
        "url": "http://whisper:9000/asr",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "parameterType": "formBinaryData",
              "name": "audio_file",
              "inputDataFieldName": "data"
            },
            {
              "name": "language",
              "value": "ru"
            }
          ]
        }
      },
      "id": "whisper-transcribe",
      "name": "Распознать речь Whisper",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1140, 300]
    },
    {
      "parameters": {
        "prompt": "Ты Alenushka - AI помощница российского ресторана. Клиент отправил голосовое сообщение с заказом:\n\n\"{{$json.text}}\"\n\nНужно:\n1. Распознать какие блюда заказал клиент\n2. Уточнить адрес доставки если нужно\n3. Посчитать примерную стоимость\n4. Сформировать подтверждение заказа\n\nОтветь дружелюбно на русском языке, как опытный администратор ресторана."
      },
      "id": "ai-process-order",
      "name": "AI обработка заказа",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [1360, 300]
    },
    {
      "parameters": {
        "chatId": "={{$node['telegram-trigger'].json.message.from.id}}",
        "text": "🍽️ *Заказ принят!*\n\n{{$node['ai-process-order'].json.choices[0].message.content}}\n\n📞 Наш менеджер свяжется с вами в течение 5 минут для подтверждения.\n\n_Powered by Alenushka AI_ 🤖"
      },
      "id": "send-confirmation",
      "name": "Отправить подтверждение",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1580, 300]
    },
    {
      "parameters": {
        "chatId": "@restaurant_orders", 
        "text": "🆕 *Новый заказ через голос!*\n\n👤 От: {{$node['telegram-trigger'].json.message.from.first_name}} (ID: {{$node['telegram-trigger'].json.message.from.id}})\n🎤 Текст: \"{{$node['whisper-transcribe'].json.text}}\"\n\n🤖 *AI обработка:*\n{{$node['ai-process-order'].json.choices[0].message.content}}\n\n⏰ Время: {{new Date().toLocaleString('ru-RU')}}"
      },
      "id": "notify-staff",
      "name": "Уведомить персонал",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1580, 500]
    }
  ],
  "connections": {
    "telegram-trigger": {
      "main": [
        [
          {
            "node": "check-voice-message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-voice-message": {
      "main": [
        [
          {
            "node": "get-voice-file",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "get-voice-file": {
      "main": [
        [
          {
            "node": "download-voice",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "download-voice": {
      "main": [
        [
          {
            "node": "whisper-transcribe",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "whisper-transcribe": {
      "main": [
        [
          {
            "node": "ai-process-order",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ai-process-order": {
      "main": [
        [
          {
            "node": "send-confirmation",
            "type": "main",
            "index": 0
          },
          {
            "node": "notify-staff",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "tags": [
    {
      "createdAt": "2024-09-18T00:00:00.000Z",
      "updatedAt": "2024-09-18T00:00:00.000Z",
      "id": "telegram-voice-orders",
      "name": "Telegram Голос"
    }
  ]
}
