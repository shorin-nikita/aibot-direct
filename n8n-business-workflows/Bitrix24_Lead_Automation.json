{
  "name": "🏢 Автоматизация лидов Битрикс24",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "bitrix-webhook",
        "responseMode": "responseNode"
      },
      "id": "webhook-bitrix24",
      "name": "Webhook получения лида",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [260, 300],
      "webhookId": "bitrix24-leads"
    },
    {
      "parameters": {
        "prompt": "Ты Alenushka - AI помощница для российского бизнеса. Проанализируй лида из Битрикс24:\n\nИмя: {{$json.NAME}}\nТелефон: {{$json.PHONE}}\nEmail: {{$json.EMAIL}}\nКомпания: {{$json.COMPANY_TITLE}}\n\nСоздай персональное предложение на русском языке с учётом:\n1. Отрасли компании\n2. Потенциальных потребностей\n3. Наших AI решений\n\nОтвет должен быть готов для отправки менеджеру."
      },
      "id": "ai-analyze-lead",
      "name": "AI анализ лида Alenushka",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [580, 300]
    },
    {
      "parameters": {
        "url": "https://yourdomain.bitrix24.ru/rest/your_user_id/your_webhook_key/crm.lead.update",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "id",
              "value": "={{$node.webhook-bitrix24.json.FIELDS.ID}}"
            },
            {
              "name": "fields[COMMENTS]", 
              "value": "🤖 AI анализ от Alenushka:\n\n{{$node.ai-analyze-lead.json.choices[0].message.content}}"
            },
            {
              "name": "fields[UF_CRM_AI_SCORE]",
              "value": "85"
            }
          ]
        }
      },
      "id": "update-bitrix-lead",
      "name": "Обновить лида в Битрикс24",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "chatId": "@your_sales_channel",
        "text": "🚀 *Новый горячий лид!*\n\n👤 *{{$node.webhook-bitrix24.json.FIELDS.NAME}}*\n🏢 {{$node.webhook-bitrix24.json.FIELDS.COMPANY_TITLE}}\n📱 {{$node.webhook-bitrix24.json.FIELDS.PHONE}}\n\n🤖 *AI рекомендация от Alenushka:*\n{{$node.ai-analyze-lead.json.choices[0].message.content}}\n\n[Открыть в Битрикс24](https://yourdomain.bitrix24.ru/crm/lead/details/{{$node.webhook-bitrix24.json.FIELDS.ID}}/)"
      },
      "id": "telegram-notification",
      "name": "Уведомление в Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [900, 500]
    }
  ],
  "connections": {
    "webhook-bitrix24": {
      "main": [
        [
          {
            "node": "ai-analyze-lead",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ai-analyze-lead": {
      "main": [
        [
          {
            "node": "update-bitrix-lead", 
            "type": "main",
            "index": 0
          },
          {
            "node": "telegram-notification",
            "type": "main", 
            "index": 0
          }
        ]
      ]
    }
  },
  "tags": [
    {
      "createdAt": "2024-09-18T00:00:00.000Z",
      "updatedAt": "2024-09-18T00:00:00.000Z",
      "id": "bitrix24-automation",
      "name": "Битрикс24"
    }
  ]
}
